# 0G mainnet RPC and deployer key.
# Use a wallet funded with enough 0G for deploy, underwriting anchors, and Storage upload.
# 0G Compute may require 3 OG minimum ledger funding plus gas on first live review.
ZG_MAINNET_RPC=https://evmrpc.0g.ai
ZG_MAINNET_CHAIN_ID=16661
ZG_MAINNET_EXPLORER=https://chainscan.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-turbo.0g.ai
ZG_PRIVATE_KEY=0x...
ZG_COMPUTE_MODEL_HINT=qwen
# Optional: pin a known healthy verifiable provider from `0g-compute-cli inference list-providers-detail`.
ZG_COMPUTE_PROVIDER=
CREDITGATE_STORAGE_AGENT_ID=4

# Filled after deploy.
AGENT_CREDIT_REGISTRY=
